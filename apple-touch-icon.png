<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 180 180">
  <!-- Background -->
  <rect width="180" height="180" rx="20" fill="#0a0a0f"/>
  
  <!-- Gold border -->
  <rect x="6" y="6" width="168" height="168" rx="16" fill="none" stroke="#c9a84c" stroke-width="2.5"/>
  
  <!-- Crossed swords -->
  <line x1="42" y1="30" x2="138" y2="100" stroke="#c9a84c" stroke-width="3.5" stroke-linecap="round"/>
  <line x1="55" y1="24" x2="36" y2="47" stroke="#c9a84c" stroke-width="2.5" stroke-linecap="round"/>
  <circle cx="40" cy="28" r="4" fill="#c9a84c"/>
  <polygon points="138,100 143,92 148,104" fill="#c9a84c"/>

  <line x1="138" y1="30" x2="42" y2="100" stroke="#c9a84c" stroke-width="3.5" stroke-linecap="round"/>
  <line x1="125" y1="24" x2="144" y2="47" stroke="#c9a84c" stroke-width="2.5" stroke-linecap="round"/>
  <circle cx="140" cy="28" r="4" fill="#c9a84c"/>
  <polygon points="42,100 37,92 32,104" fill="#c9a84c"/>

  <!-- Open book -->
  <g transform="translate(90,138)">
    <path d="M-30,-16 Q-15,-20 0,-16 L0,16 Q-15,12 -30,16 Z" fill="#1a1a26" stroke="#c9a84c" stroke-width="1.5"/>
    <path d="M30,-16 Q15,-20 0,-16 L0,16 Q15,12 30,16 Z" fill="#1a1a26" stroke="#c9a84c" stroke-width="1.5"/>
    <line x1="0" y1="-16" x2="0" y2="16" stroke="#c9a84c" stroke-width="1.5"/>
    <line x1="-24" y1="-7" x2="-6" y2="-9" stroke="#c9a84c" stroke-width="0.8" opacity="0.5"/>
    <line x1="-24" y1="-1" x2="-6" y2="-3" stroke="#c9a84c" stroke-width="0.8" opacity="0.5"/>
    <line x1="-24" y1="5" x2="-6" y2="3" stroke="#c9a84c" stroke-width="0.8" opacity="0.5"/>
    <line x1="24" y1="-7" x2="6" y2="-9" stroke="#c9a84c" stroke-width="0.8" opacity="0.5"/>
    <line x1="24" y1="-1" x2="6" y2="-3" stroke="#c9a84c" stroke-width="0.8" opacity="0.5"/>
    <line x1="24" y1="5" x2="6" y2="3" stroke="#c9a84c" stroke-width="0.8" opacity="0.5"/>
  </g>

  <!-- Mana orbs in pentagon, centered over book -->
  <circle cx="90.0" cy="86.0" r="10" fill="#f9f6e8" stroke="#0a0a0f" stroke-width="1.5"/>
  <circle cx="110.9" cy="101.2" r="10" fill="#4a90d9" stroke="#0a0a0f" stroke-width="1.5"/>
  <circle cx="102.9" cy="125.8" r="10" fill="#27ae60" stroke="#0a0a0f" stroke-width="1.5"/>
  <circle cx="77.1" cy="125.8" r="10" fill="#9b59b6" stroke="#0a0a0f" stroke-width="1.5"/>
  <circle cx="69.1" cy="101.2" r="10" fill="#e74c3c" stroke="#0a0a0f" stroke-width="1.5"/>
</svg>